# =============================================================================
# Google Maps Embed API key (Contact 섹션 지도용)
# =============================================================================
# 1. https://console.cloud.google.com/ → 새 프로젝트 생성 (또는 기존 프로젝트 선택)
# 2. "API 및 서비스" → "라이브러리"에서 "Maps Embed API" 사용 설정
# 3. "사용자 인증 정보"에서 API 키 발급
# 4. 운영 시에는 키를 (a) HTTP 리퍼러로 도메인 제한, (b) "Maps Embed API"만 허용하도록 제한 권장
# 5. 발급받은 키를 아래 .env.local 에 복사:
#      cp .env.example .env.local
#      VITE_GOOGLE_MAPS_API_KEY=AIza...
#
# Vite는 VITE_ 접두사가 붙은 변수만 클라이언트에 노출합니다.
# 키가 비어 있으면 Contact 섹션은 API 키가 필요 없는 ?output=embed 임베드로 자동 폴백합니다.
VITE_GOOGLE_MAPS_API_KEY=

# =============================================================================
# Supabase (문의 폼 저장 + 관리자 페이지)
# =============================================================================
# 1. https://supabase.com → New Project (Region: ap-northeast-2 권장)
# 2. SQL Editor에서 db/schema.sql 의 SQL 실행 (테이블 + RLS + submit_inquiry RPC)
# 3. Authentication → Providers → Email → "Confirm email" OFF
# 4. Authentication → Users → Add user (관리자 이메일/비밀번호)
#    - 사용한 이메일을 src/lib/supabase.js 의 ADMIN_EMAIL 상수에 반영
# 5. Project Settings → API 에서 아래 두 값 복사
#
# 주의: anon public 키만 사용. service_role 키는 절대 클라이언트에 두지 마세요.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
